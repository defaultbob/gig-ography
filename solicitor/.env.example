# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git.

# https://api.setlist.fm/docs/1.0/ui/#!/ (free registration)
SETLIST_FM_API_KEY=

# https://developer.spotify.com/dashboard (free)
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=

# Requires Apple Developer Program membership ($99/yr)
# https://developer.apple.com/documentation/applemusicapi
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_SECRET_KEY_PATH=path/to/AuthKey_XXXXXX.p8

# Used as the User-Agent string for MusicBrainz API requests (required by their ToS)
# Use any valid email address
MUSICBRAINZ_APP_EMAIL=your@email.com
